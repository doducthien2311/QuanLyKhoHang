@using Microsoft.AspNetCore.Http
@model QuanLyKhoLogistics.Models.Entities.Users
@{
    Layout = null; // Không dùng Layout chung để giao diện Steam tập trung nhất
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - Logistics System</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    
    <style>
        body { 
            background-color: #171d25; 
            color: white; 
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; 
            height: 100vh;
            display: flex;
            align-items: center;
        }
        .login-box { 
            max-width: 900px; 
            margin: auto; 
            background-color: #1a2028; 
            padding: 50px; 
            border-radius: 4px; 
            border: 1px solid rgba(0,0,0,0.2);
        }
        h1 { font-size: 32px; font-weight: 200; margin-bottom: 30px; text-transform: uppercase; letter-spacing: 2px; }
        .steam-input { 
            background-color: #32353c; 
            color: white; 
            border: none; 
            padding: 12px; 
            border-radius: 2px;
            box-shadow: inset 0 0 3px rgba(0,0,0,0.5);
        }
        .steam-input:focus { 
            background-color: #3b5a77; 
            color: white; 
            box-shadow: none;
            outline: none;
        }
        .btn-steam { 
            background: linear-gradient(to right, #47bfff 0%, #1a44c2 100%);
            color: white; 
            border: none;
            border-radius: 2px; 
            padding: 12px 30px; 
            font-weight: bold; 
        }
        .btn-steam:hover { 
            background: linear-gradient(to right, #47bfff 20%, #1a44c2 80%);
            color: white; 
        }
        .qr-section { 
            background-color: white; 
            padding: 15px; 
            text-align: center; 
            border-radius: 4px; 
            display: inline-block;
        }
        .label-style { color: #1999ff; font-size: 12px; margin-bottom: 5px; }
        .text-secondary-custom { color: #afafaf; }
    </style>
</head>
<body>
    <div class="container">
        <div class="login-box shadow-lg">
            <div class="row">
                <div class="col-md-7 border-end border-secondary pe-md-5">
                    <h1>Đăng nhập</h1>
                    
                    @if (TempData["SuccessMsg"] != null)
                    {
                        <div class="alert alert-success py-2 small border-0 mb-4" style="background-color: #d4edda; color: #155724;">
                            <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMsg"]
                        </div>
                    }

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger py-2 small border-0 mb-4" style="background-color: #f8d7da; color: #721c24;">
                            <i class="fas fa-exclamation-triangle me-2"></i> @ViewBag.Error
                        </div>
                    }

                    @using (Html.BeginForm("Login", "Account", FormMethod.Post)) {
                        @Html.AntiForgeryToken()
                        
                        <div class="mb-3">
                            <label class="label-style fw-bold">ĐĂNG NHẬP BẰNG TÊN TÀI KHOẢN</label>
                            @Html.TextBoxFor(m => m.Username, new { @class = "form-control steam-input", required = "required", autocomplete = "off" })
                        </div>

                        <div class="mb-4">
                            <label class="text-secondary-custom small fw-bold mb-1">MẬT KHẨU</label>
                            @Html.PasswordFor(m => m.Password, new { @class = "form-control steam-input", required = "required" })
                        </div>

                        <div class="form-check mb-4">
                            <input type="checkbox" class="form-check-input" id="rememberMe">
                            <label class="form-check-label text-secondary-custom small" for="rememberMe">Ghi nhớ tôi trên máy tính này</label>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-steam">Đăng nhập</button>
                        </div>
                    }
                    
                    <div class="mt-4 pt-2">
                        <a href="#" class="text-secondary-custom text-decoration-none small">Bạn không thể đăng nhập?</a>
                    </div>
                </div>

                <div class="col-md-5 ps-md-5 text-center d-flex flex-column justify-content-center">
                    <label class="label-style fw-bold mb-3">HOẶC ĐĂNG NHẬP BẰNG QR</label>
                    <div class="mb-3">
                        <div class="qr-section">
                            @* Thiện kiểm tra đường dẫn ảnh QR này trong thư mục wwwroot/images nhé *@
                            <img src="~/images/qr_logistics.png" alt="QR Code" width="160" onerror="this.src='https://api.qrserver.com/v1/create-qr-code/?size=160x160&data=Thiện_Logistics_Admin'">
                        </div>
                    </div>
                    <p class="text-secondary-custom small px-4">Sử dụng ứng dụng di động để quét mã và đăng nhập nhanh chóng.</p>
                    
                    <div class="mt-auto">
                        <span class="text-secondary-custom small">Chưa có tài khoản? </span>
                        <a href="/Account/Register" class="text-white text-decoration-none small fw-bold border-bottom">Đăng ký ngay</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>