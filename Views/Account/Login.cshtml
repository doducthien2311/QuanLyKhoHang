@model QuanLyKhoLogistics.Models.Entities.User
@{
    Layout = null; // Không dùng Layout chung để Login trông biệt lập
}

<!DOCTYPE html>
<html>
<head>
    <title>Đăng nhập - Logistics</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #171d25; color: white; font-family: 'Motiva Sans', sans-serif; }
        .login-box { max-width: 900px; margin: 100px auto; background-color: #1a2028; padding: 50px; border-radius: 10px; }
        h1 { font-size: 32px; font-weight: bold; margin-bottom: 30px; }
        .steam-input { background-color: #2a3f55; color: white; border: 1px solid #000; padding: 10px; }
        .steam-input:focus { background-color: #3b5a77; color: white; }
        .btn-steam { background-color: #20a0ff; color: white; border-radius: 0; padding: 12px 30px; font-weight: bold; }
        .btn-steam:hover { background-color: #4db3ff; color: white; }
        .qr-section { background-color: white; padding: 20px; text-align: center; border-radius: 5px; }
    </style>
</head>
<body>
    <div class="container">
        <div class="login-box shadow-lg">
            <div class="row">
                <div class="col-md-7 border-end border-secondary pe-5">
                    <h1>Đăng nhập</h1>
                    @if (TempData["SuccessMsg"] != null)
{
    <div class="alert alert-success py-2 small border-0" style="background-color: #d4edda; color: #155724;">
        @TempData["SuccessMsg"]
    </div>
}

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger py-2 small border-0" style="background-color: #f8d7da; color: #721c24;">
        @ViewBag.Error
    </div>
}
                    @using (Html.BeginForm("Login", "Account", FormMethod.Post)) {
                        @Html.AntiForgeryToken()
                        
                        <div class="mb-3">
                            <label class="text-primary small fw-bold">ĐĂNG NHẬP BẰNG TÊN TÀI KHOẢN</label>
                            @Html.TextBoxFor(m => m.Username, new { @class = "form-control steam-input" })
                        </div>
                        <div class="mb-3">
                            <label class="text-secondary small fw-bold">MẬT KHẨU</label>
                            @Html.PasswordFor(m => m.Password, new { @class = "form-control steam-input" })
                        </div>
                        <div class="form-check mb-4">
                            <input type="checkbox" class="form-check-input" id="rememberMe">
                            <label class="form-check-label text-secondary small" for="rememberMe">Ghi nhớ tôi</label>
                        </div>
                        <button type="submit" class="btn btn-steam w-100">Đăng nhập</button>
                    }
                    
                    <div class="mt-4 text-center">
                        <span class="text-secondary small">Chưa có tài khoản? </span>
                        <a href="/Account/Register" class="text-white text-decoration-none small fw-bold">Đăng ký ngay</a>
                    </div>
                </div>

                <div class="col-md-5 ps-5 text-center">
                    <label class="text-primary small fw-bold mb-3">HOẶC ĐĂNG NHẬP BẰNG QR</label>
                    <div class="qr-section mb-3">
                        <img src="~/images/qr_logistics.png" alt="QR Code" width="180"> </div>
                    <p class="text-secondary small">Đăng nhập bằng mã QR với ứng dụng di động</p>
                </div>
            </div>
        </div>
    </div>
</body>
</html>