@{ Layout = null; }
<!DOCTYPE html>
<html>
<head>
    <title>Đăng ký thành viên - Logistics</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #171d25; color: white; font-family: sans-serif; }
        .register-box { max-width: 500px; margin: 80px auto; background-color: #1a2028; padding: 40px; border-radius: 10px; }
        .steam-input { background-color: #2a3f55; color: white; border: 1px solid #000; margin-bottom: 15px; }
        .btn-register { background-color: #c7d20e; color: black; font-weight: bold; width: 100%; padding: 10px; border: none; }
        .btn-register:hover { background-color: #e5f212; }
    </style>
</head>
<body>
    <div class="register-box shadow-lg">
        <h2 class="text-center mb-4">TẠO TÀI KHOẢN</h2>
        @if (ViewBag.Error != null)
{
    <div class="alert alert-danger py-2 small border-0" style="background-color: #f8d7da; color: #721c24;">
        @ViewBag.Error
    </div>
}
        <form action="/Account/Register" method="post">
            <label class="small text-primary fw-bold">HỌ VÀ TÊN</label>
            <input type="text" name="FullName" class="form-control steam-input" required>

            <label class="small text-primary fw-bold">TÊN TÀI KHOẢN</label>
            <input type="text" name="Username" class="form-control steam-input" required>

            <label class="small text-primary fw-bold">MẬT KHẨU</label>
            <input type="password" name="Password" class="form-control steam-input" required>

            <label class="small text-primary fw-bold">XÁC NHẬN MẬT KHẨU</label>
            <input type="password" name="ConfirmPassword" class="form-control steam-input" required>

            <button type="submit" class="btn btn-register mt-3">HOÀN TẤT ĐĂNG KÝ</button>
            <div class="mt-3 text-center">
                <a href="/Account/Login" class="text-secondary small">Đã có tài khoản? Đăng nhập</a>
            </div>
        </form>
    </div>
</body>
</html>