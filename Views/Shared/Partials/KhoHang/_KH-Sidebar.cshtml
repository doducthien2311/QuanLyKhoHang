<div class="border-end pe-3 bg-white rounded-3 shadow-sm py-4 h-100">
    <div class="d-flex align-items-center mb-4 pb-2 border-bottom px-3">
        <img src="~/images/user_avatar.png" class="rounded-circle me-2 border border-2 border-success" style="width: 45px; height: 45px; object-fit: cover;">
        <div>
            <small class="text-muted d-block" style="font-size: 0.7rem;">@DateTime.Now.ToString("dd/MM/yyyy")</small>
            <span class="fw-bold text-dark" style="font-size: 0.9rem;">Thiện Đỗ Đức!</span>
        </div>
    </div>

    <div class="px-3 mb-4">
        <div class="input-group shadow-sm rounded-pill border overflow-hidden">
            <span class="input-group-text bg-white border-0"><i class="fas fa-search text-muted"></i></span>
            <input type="text" class="form-control border-0 px-1" placeholder="Tìm kiếm...">
        </div>
    </div>

    <div class="nav flex-column nav-pills px-2">
        <button class="nav-link active text-start mb-2 rounded-pill shadow-sm" style="background-color: #2e7d32;" type="button">Tất cả kho</button>
        <button class="nav-link text-start mb-2 rounded-pill text-dark bg-light border" type="button">Kho có hàng</button>
        <button class="nav-link text-start mb-2 rounded-pill text-dark bg-light border" type="button">Kho trống</button>
    </div>
</div>