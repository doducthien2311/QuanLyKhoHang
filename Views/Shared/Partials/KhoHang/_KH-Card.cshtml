@model dynamic 

<div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden border-start border-4" style="border-color: @Model.Color !important;">
    <div class="card-body p-3">
        <div class="d-flex justify-content-between mb-2">
            <h6 class="fw-bold mb-0 text-uppercase" style="color: @Model.Color;">@Model.TenKho</h6>
            <i class="far fa-heart text-muted"></i>
        </div>
        <img src="@Model.HinhAnh" class="rounded-3 mb-3 border w-100" style="height: 120px; object-fit: cover;">
        
        <div class="small text-muted mb-3">
            <div><i class="fas fa-map-marker-alt text-success me-1"></i> @Model.DiaChi</div>
            <div><i class="fas fa-box text-success me-1"></i> Hàng hóa: <b>@Model.SoLuong SP</b></div>
            <div><i class="fas fa-users text-success me-1"></i> Nhân viên: @Model.NhanVien</div>
        </div>

        <div class="progress mb-2" style="height: 8px;">
            <div class="progress-bar bg-success" style="width: @Model.PhanTram%"></div>
        </div>
        <div class="d-flex justify-content-between align-items-center mb-3">
            <small class="text-muted">Sức chứa: @Model.PhanTram%</small>
            <span class="badge bg-success rounded-pill">@Model.TrangThai</span>
        </div>
     <div class="mt-3 text-center">
    <a href="@Url.Action("DatLichKiemKho", "Home", new { id = Model.Id })" 
       class="btn btn-success rounded-pill px-4 shadow-sm fw-bold">
       QUẢN LÝ KHO
    </a>
</div>
    </div>
</div>