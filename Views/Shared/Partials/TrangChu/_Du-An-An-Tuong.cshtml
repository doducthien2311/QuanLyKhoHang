        color: #001f3f;
        font-weight: bold;
        border-radius: 5px;
        padding: 8px 25px;
        text-decoration: none;
        font-size: 14px;
        transition: 0.3s;
        display: inline-block;
    }

    .btn-detail:hover {
        background-color: #fd7e14;
        color: white;
    }

    /* Style cho phần ảnh (Cột phải) */
    .du-an-img {
        max-height: 380px;
        border: 5px solid rgba(255,255,255,0.2);
        box-shadow: 0 4px 15px rgba(0,0,0,0.3);
    }

    /* Định dạng dấu chấm tròn (pagination) */
    .duAnSwiper .swiper-pagination {
        bottom: 20px !important; /* Đẩy chấm tròn xuống dưới */
    }

    .duAnSwiper .swiper-pagination-bullet {
        width: 12px;
        height: 12px;
        background: #fff !important;
        opacity: 0.5;
        margin: 0 6px !important;
    }

    .duAnSwiper .swiper-pagination-bullet-active {
        background: #fd7e14 !important; /* Chấm tròn màu cam khi được chọn */
        opacity: 1;
        width: 30px; /* Kéo dài chấm tròn đang chọn cho đẹp */
        border-radius: 6px;
    }
</style>
