<style>
   .du-an-container {
        /* Lớp phủ (giữ nguyên độ đậm nhạt 0.7 theo yêu cầu trước nếu Thiện thích, hoặc chỉnh 0.95 nếu muốn đậm) */
        background: linear-gradient(rgba(0, 31, 63, 0.7), rgba(0, 31, 63, 0.7)), url('/images/background_kho.jpg');
        background-size: cover;
        background-position: center;
        color: white;
        
        /* Chỉnh lại padding:
           - Tăng padding trên một chút để thoáng (80px)
           - THU GỌN padding dưới (chỉ còn 40px) để khung xanh sát với nội dung */
        padding: 80px 0 40px 0 !important; 
        
        border-radius: 15px;
        margin-top: 40px;
        position: relative;
        overflow: hidden;
    }

    /* Đưa dấu chấm tròn (pagination) xuống sát mép dưới hơn nữa */
    .duAnSwiper .swiper-pagination {
        /* Chỉnh bottom thành 5px hoặc 8px (trước đó là 10px) 
           để nó nằm thon gọn ở đáy khung xanh */
        bottom: 8px !important; 
    }

    /* Style cho Swiper */
    .duAnSwiper {
        width: 100%;
        height: 100%;
    }

    /* Style cho phần chữ (Cột trái) */
    .du-an-text {
        padding-right: 30px;
        text-align: left;
    }

    .du-an-title {
      color: #fd7e14; /* Đã đổi sang màu cam thương hiệu */
    font-weight: bold;
    margin-bottom: 15px;
}

    .du-an-description {
        font-size: 14px;
