@{
    // 1. Lấy tên từ Session và xử lý chữ cái đầu
    var userName = Context.Session.GetString("UserName") ?? "User";
    var firstChar = !string.IsNullOrEmpty(userName) ? userName.Substring(0, 1).ToUpper() : "U";

    // 2. Logic xác định ca trực theo giờ hệ thống
    var hour = DateTime.Now.Hour;
    string caTruc = (hour >= 6 && hour < 18) ? "Sáng" : "Tối";
    string iconCaTruc = (hour >= 6 && hour < 18) ? "bi-sun" : "bi-moon-stars";
}

<div class="card border-0 shadow-sm p-3 mb-4" style="background-color: #1a202c; color: white; border-radius: 12px;">
    <div class="text-center">
        <div class="position-relative d-inline-block">
            <div class="rounded-circle d-flex align-items-center justify-content-center border border-2 border-primary" 
                 style="width: 70px; height: 70px; background-color: #2d3748; font-size: 2rem; font-weight: bold; color: #63b3ed;">
                @firstChar
            </div>
            <span class="position-absolute bottom-0 end-0 p-1 bg-success border border-light rounded-circle"></span>
        </div>
        <h5 class="mt-3 fw-bold mb-0">@userName</h5>
        <span class="badge bg-warning text-dark mt-1">@Context.Session.GetString("UserRole")</span>
    </div>
    
    <div class="mt-4 small text-secondary text-center">
        <p class="mb-0"><i class="bi @iconCaTruc me-2"></i> Ca trực: @caTruc</p>
    </div>

    <div class="list-group list-group-flush mt-4">
        <a href="/Home/Index" class="list-group-item list-group-item-action bg-primary text-white border-0 rounded mb-2">
            <i class="bi bi-house-door me-2"></i> Trang chủ
        </a>
        <a href="/Home/KhoHang" class="list-group-item list-group-item-action bg-transparent text-white border-0 opacity-75">
            <i class="bi bi-box me-2"></i> Quản lý tồn kho
        </a>
        <a href="#" class="list-group-item list-group-item-action bg-transparent text-white border-0 opacity-75">
            <i class="bi bi-graph-up me-2"></i> Báo cáo thống kê
        </a>
    </div>
</div>