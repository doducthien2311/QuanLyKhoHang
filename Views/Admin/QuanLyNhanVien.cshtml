@using System.Data
@model DataTable
@{
    ViewData["Title"] = "Quản lý nhân sự";
}

<div class="container mt-5">
    <div class="card shadow border-0">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0"><i class="fas fa-user-shield me-2"></i>Danh sách nhân viên hệ thống</h4>
        </div>
        <div class="card-body">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Họ và Tên</th>
                        <th>Tên đăng nhập</th>
                        <th>Quyền hạn</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (DataRow row in Model.Rows)
                    {
                        <tr>
                            <td>#@row["UserId"]</td>
                            <td class="fw-bold">@row["FullName"]</td>
                            <td>@row["Username"]</td>
                            <td>
                                @if (row["Role"].ToString() == "Admin")
                                {
                                    <span class="badge bg-danger">Quản trị viên</span>
                                }
                                else
                                {
                                    <span class="badge bg-info text-dark">Nhân viên</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (row["Role"].ToString() == "User")
                                {
                                    <button class="btn btn-success btn-sm" onclick="doiQuyen(@row["UserId"], 'Admin')">
                                        <i class="fas fa-chevron-circle-up me-1"></i> Lên Admin
                                    </button>
                                }
                                else
                                {
                                    <button class="btn btn-warning btn-sm" onclick="doiQuyen(@row["UserId"], 'User')">
                                        <i class="fas fa-chevron-circle-down me-1"></i> Hạ xuống User
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
function doiQuyen(id, roleMoi) {
    if (confirm("Thiện có chắc muốn đổi quyền của người này thành " + roleMoi + "?")) {
        $.ajax({
            url: '/Admin/CapNhatQuyen',
            type: 'POST',
            data: { userId: id, newRole: roleMoi },
            success: function(res) {
                if (res.success) {
                    alert("Đã cập nhật quyền thành công!");
                    location.reload();
                } else {
                    alert("Lỗi: " + res.message);
                }
            }
        });
    }
}
</script>