                // HIỆN THỊ BỘ BA: [Vị trí] - [Trạng thái] trên tiêu đề
                if (titleMaViTri) {
                    titleMaViTri.innerText = `VỊ TRÍ: ${maViTri} (${occupied ? 'ĐANG CÓ HÀNG' : 'Ô TRỐNG'})`;
                }

                // 2. Reset trạng thái hiển thị (Ẩn các bảng phụ)
                $("#previewHoaDon").hide();
                $("#btnXacNhanNhap").hide();
                $("#btnXacNhanXuat").hide();

                // 3. Cấu hình luồng Nhập/Xuất
                const btnXem = document.getElementById('btnXemTruoc');
                
