<script>
document.addEventListener('DOMContentLoaded', function () {
    const inputTimKiem = document.querySelector('#input-tim-kho');

    if (inputTimKiem) {
        inputTimKiem.addEventListener('input', function (e) {
            let tuKhoa = e.target.value.toLowerCase().trim();
            let danhSachO = document.querySelectorAll('.o-kho-item');

            danhSachO.forEach(o => {
                // 1. LẤY DỮ LIỆU ĐỂ KIỂM TRA
                let soO = o.querySelector('.box-number')?.innerText.trim().toLowerCase() || "";
                let tenSP = (o.getAttribute('data-ten') || "").toLowerCase();
                let maViTri = o.querySelector('.label-code')?.innerText.trim().toLowerCase() || "";

                if (tuKhoa === "") {
                    o.style.setProperty('display', 'flex', 'important');
                    o.classList.remove('highlight-blink');
                } else {
                    // QUY LUẬT LỌC (Sửa kỹ tại đây):
                    
                    // Kiểm tra xem từ khóa có phải là SỐ thuần túy không
                    let laSo = !isNaN(tuKhoa);

                    let hopLe = false;

                    if (laSo) {
                        // Nếu Thiện gõ SỐ: Chỉ so sánh bằng TUYỆT ĐỐI với số ô
                        // (Gõ 1 chỉ ra ô 1, không bao giờ ra ô 8)
                        hopLe = (soO === tuKhoa);
                    } else {
                        // Nếu Thiện gõ CHỮ: Tìm kiếm TƯƠNG ĐỐI trong tên sản phẩm hoặc mã vị trí
                        hopLe = tenSP.includes(tuKhoa) || maViTri.includes(tuKhoa);
                    }

                    // THỰC THI HIỂN THỊ
                    if (hopLe) {
                        o.style.setProperty('display', 'flex', 'important');
                        o.classList.add('highlight-blink');
                    } else {
                        // Ẩn tuyệt đối (kể cả có hàng hay không khớp cũng ẩn hết)
                        o.style.setProperty('display', 'none', 'important');
                        o.classList.remove('highlight-blink');
                    }
                }
            });
        });
    }
});
    // --- KẾT THÚC CHỨC NĂNG TÌM KIẾM ---
            function xemChiTietO(id, maViTri, isOccupied) {
                // Chuyển đổi trạng thái về boolean chuẩn
                // Chấp nhận cả true, "true", số 1 hoặc chuỗi "1" từ database
                const occupied = (isOccupied === true || isOccupied === "true" || isOccupied == 1);
                
                // 1. Gán dữ liệu định danh cơ bản
                const txtViTriID = document.getElementById('txtViTriID_Hidden');
