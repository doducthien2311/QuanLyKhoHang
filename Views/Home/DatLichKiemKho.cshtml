                        iptSKU_Xuat.readOnly = true; 
                        iptSKU_Xuat.classList.add('bg-light'); // Đổi màu nền cho dễ nhận biết
                    }

                    // Gọi hàm load thông tin sản phẩm từ Server (SKU, Tên SP,...)
                    loadThongTinSanPham(id);

                    } else {
                        // --- LUỒNG NHẬP HÀNG ---
                        $("#formXuatHang").hide();
                        $("#formNhapHang").show();

                        if (btnXem) {
                            btnXem.innerText = "Xem hóa đơn nhập";
                            btnXem.className = "btn btn-primary px-4 shadow";
                        }

                        // Tự động tạo mã hóa đơn NHẬP (HDN)
                        const iptHD = document.getElementById('iptSoHoaDon');
                        if (iptHD) iptHD.value = "HDN-" + Date.now();

                        // Tự động tạo SKU gợi ý nếu là hàng mới (Có thể sửa được khi nhập)
                        const iptSKU = document.getElementById('iptMaSKU');
                        if (iptSKU) {
                            iptSKU.value = ""; // Để trống lúc đầu, chờ chọn sản phẩm mới hiện
                            iptSKU.readOnly = true; // Khóa lại để không cho nhập lung tung, buộc theo sản phẩm
                            iptSKU.placeholder = "Chọn sản phẩm để hiển thị SKU";
                        }

                        const iptNV = document.getElementById('iptNguoiThucHien');
                        const sessionNV = document.getElementById('txtNhanVienHienTai')?.value;
                        if (iptNV) iptNV.value = sessionNV || "Hệ thống";
                    }

                // 4. Mở Modal
                modalEl = document.getElementById('modalThaoTac');
                if (modalEl) {
                    bootstrap.Modal.getOrCreateInstance(modalEl).show();
                }  
                if (!occupied) {
                // Lấy ID khu vực hiện tại từ input hidden
                const idKhuHienTai = document.getElementById('txtKhuID_Hidden').value;
                const selectSP = document.getElementById('iptTenSP');
                const options = selectSP.options;

                // Duyệt danh sách SP: nếu thuộc khu vực này thì hiện, không thì ẩn
                for (let i = 1; i < options.length; i++) {
                    const idDanhMucCuaSP = options[i].getAttribute('data-category');
                    if (idDanhMucCuaSP === idKhuHienTai) {
                        options[i].style.display = "block";
                    } else {
                        options[i].style.display = "none";
                    }
                }
                    selectSP.value = ""; // Reset ô chọn về mặc định
                    document.getElementById('iptMaSKU').value = ""; // Xóa SKU cũ
            }
           
            if (modalEl) {
                bootstrap.Modal.getOrCreateInstance(modalEl).show();
            }
                    }


            // --- HÀM 2: TỰ ĐỘNG ĐIỀN SKU KHI CHỌN SẢN PHẨM (Phần A) ---
            const elSelectSP = document.getElementById('iptTenSP');
            if (elSelectSP) {
                elSelectSP.addEventListener('change', function () {
                    // 1. Lấy option đang được chọn
        const selectedOption = this.options[this.selectedIndex];
        
        // 2. Lấy mã SKU từ data-sku
        const maSKUFromDB = selectedOption.getAttribute('data-sku');
        const iptSKU = document.getElementById('iptMaSKU');

        if (iptSKU) {
            if (maSKUFromDB && maSKUFromDB !== "null") {
                iptSKU.value = maSKUFromDB;
                iptSKU.readOnly = true;
                iptSKU.classList.add('bg-light');
            } else {
                // Nếu chưa có SKU (đồ mới hoàn toàn)
                iptSKU.value = ""; 
                iptSKU.readOnly = false;
                iptSKU.classList.remove('bg-light');
                iptSKU.placeholder = "Nhập mã SKU mới";
