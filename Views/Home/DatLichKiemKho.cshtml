// 2. Hàm gửi dữ liệu về Controller
async function xacNhanThemNCC() {
    // 1. Lấy dữ liệu theo đúng ID Thiện vừa đặt (txtNew...)
    const ten = document.getElementById('txtNewTenNCC').value.trim();
    const sdt = document.getElementById('txtNewSDT').value.trim();
    const diaChi = document.getElementById('txtNewDiaChi').value.trim();

    if (!ten) {
        alert("⚠️ Thiện ơi, đừng quên nhập tên nhà cung cấp nhé!");
        return;
    }

    const payload = {
        TenNCC: ten,
        SoDienThoai: sdt,
        DiaChi: diaChi
    };

    try {
        const res = await fetch('/Home/ThemNCC', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        });

        const data = await res.json();

        if (data.success) {
            // Cập nhật Select box (iptTenNCC là ID của select ở trang chính)
            const sel = document.getElementById('iptTenNCC');
            const opt = new Option(ten, data.nccId);
            sel.add(opt);
            sel.value = data.nccId; 

            // Đóng Modal
            modalEl = document.getElementById('modalThemNCC');
            const modalInstance = bootstrap.Modal.getInstance(modalEl);
            modalInstance.hide();
            
            alert(`✨ Chúc mừng Thiện! Đã thêm thành công: ${ten}`);
        } else {
            alert("❌ Lỗi: " + data.message);
        }
    } catch (err) {
        console.error(err);
        alert("❌ Lỗi kết nối máy chủ rồi Thiện ơi!");
    }
}

function thucHienXuat() {
    // 1. Lấy dữ liệu định danh
    const vtId = document.getElementById('txtViTriID_Hidden').value;
    const spId = document.getElementById('hdnSanPhamID')?.value;
    
    // 2. Lấy số lượng và kiểm tra tồn kho
    const slXuat = parseInt(document.getElementById('txtSoLuongXuat').value) || 0;
    const slTon = parseInt(document.getElementById('lbSoLuong_Ton').innerText) || 0;
    
    // 3. Lấy thông tin phiếu xuất (khớp với bảng PhieuXuat)
    const soHoaDon = document.getElementById('iptSoHoaDon_Xuat').value;
    const tenKhachHang = document.getElementById('txtTenKhachHang').value || "Khách lẻ";
    
    // 4. Lấy ĐƠN GIÁ và CHIẾT KHẤU từ ô nhập liệu mới (Sửa tại đây)
    const donGiaBan = parseFloat(document.getElementById('txtDonGiaXuat').value) || 0;
     const chietKhau = parseFloat(document.getElementById('txtChietKhauXuat').value) || 0;
    // 5. Lấy đơn giá (khớp với bảng ChiTietPhieuXuat - DonGiaXuat)
    // 5. Tính toán tổng tiền (để gửi kèm payload nếu cần)
    const thanhTien = slXuat * donGiaBan;
    const tongTienSauCK = thanhTien * (1 - chietKhau / 100);

    // --- Kiểm tra hợp lệ ---
    if (!spId || spId === "") {
        alert("⚠️ Không xác định được sản phẩm!");
        return;
    }
    if (slXuat <= 0 || slXuat > slTon) {
        alert(`⚠️ Số lượng xuất không hợp lệ (Tồn: ${slTon})`);
        return;
    }

    if (!confirm("Xác nhận lưu phiếu xuất và trừ kho?")) return;

    // 5. Đóng gói dữ liệu gửi về Server
    const payload = {
        ViTriId: parseInt(vtId),
        SanPhamID: parseInt(spId),
        SoHoaDon: soHoaDon,
        TenKhachHang: tenKhachHang,
        SoLuong: slXuat,    
        DonGiaXuat: donGiaBan,      // Lấy từ ô nhập, không lấy từ hdnDonGia nữa
        ChietKhau: chietKhau,       // Trường mới
        TongTien: tongTienSauCK,    // Trường mới để SQL không bị 0.00
        NgayXuat: new Date().toISOString(),
        GhiChu: "Xuất từ sơ đồ kho"
        };

    fetch('/Home/LuuXuatKho', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
    })
    .then(res => res.json())
    .then(result => {
        if (result.success) {
            alert("✅ Xuất kho thành công!");
            location.reload(); 
        } else {
            alert("❌ Lỗi: " + result.message);
        }
    })
    .catch(err => {
        console.error(err);
        alert("❌ Lỗi kết nối server!");
    });
}
  // --- 4. Cập nhật hàm Load thông tin để điền vào Form Xuất ---
function loadThongTinSanPham(id) {
    fetch('/Home/GetChiTietO?viTriId=' + id)
        .then(res => res.json())
        .then(result => {
            console.log("Dữ liệu Server trả về:", result); // Dòng này để Thiện soi lỗi ở F12

            if (result.success) {
                // Lấy phần tử
                const elSKU = document.getElementById('iptMaSKU_Xuat');
                const elTenSP = document.getElementById('lbTenSP_Xuat');
                const elTon = document.getElementById('lbSoLuong_Ton');
                const hdnSPID = document.getElementById('hdnSanPhamID');

                // Đổ dữ liệu (Kiểm tra cả viết HOA và viết thường cho chắc ăn)
                if (elSKU) {
                    elSKU.value = result.MaSKU || result.maSKU || "Chưa có SKU";
                }

                if (elTenSP) {
                    // Nếu là thẻ input thì dùng .value, nếu là thẻ span/label thì dùng .innerText
                    let ten = result.TenSP || result.tenSP || "";
                    if (elTenSP.tagName === "INPUT") elTenSP.value = ten;
                    else elTenSP.innerText = ten;
                }

                if (elTon) {
                    let ton = result.SoLuong || result.soLuong || 0;
                    if (elTon.tagName === "INPUT") elTon.value = ton;
                    else elTon.innerText = ton;
                }

                if (hdnSPID) {
                    hdnSPID.value = result.spId || result.spID || "";
                }
            }
        })
        .catch(err => console.error("Lỗi:", err));
}
</script>