                            <input type="text" class="form-control bg-light fw-bold text-primary" id="iptSoHoaDon" readonly>
                        </div>

                <div class="col-12">
                    <label class="form-label small fw-bold">Chọn Sản phẩm</label>
                    <select class="form-select shadow-sm border-primary" id="iptTenSP" onchange="chonSanPhamTuDongDienSKU()">
                        <option value="">-- Chọn sản phẩm --</option>
                        @if (ViewBag.DanhSachSanPham != null) 
                        {
                            foreach (System.Data.DataRow row in ((System.Data.DataTable)ViewBag.DanhSachSanPham).Rows) 
                            {
                                <option value="@row["SanPhamID"]" 
                                        data-category="@row["DanhMucId"]" 
                                        data-sku="@row["MaSKU"]">
                                    @row["TenSP"]
                                </option>
                            }
                        }
                    </select>
                </div>
                        
                        <div class="col-12">
                            <label class="form-label small fw-bold">Nhà cung cấp</label>
                            <div class="input-group">
                                <select class="form-select" id="iptTenNCC">
                                    <option value="">-- Chọn nhà cung cấp --</option>
                                    @if (ViewBag.DanhSachNCC != null) {
                                        foreach (System.Data.DataRow row in ((System.Data.DataTable)ViewBag.DanhSachNCC).Rows) {
                                            <option value="@row["NccID"]">@row["TenNCC"]</option>
                                        }
                                    }
                                </select>

                                @* Kiểm tra nếu đúng là Admin *@
    @if (quyen == "Admin") 
    {
        <button class="btn btn-outline-success" type="button" onclick="moModalThemNCC()">
            <i class="fas fa-plus"></i>
        </button>
    }
                            </div>
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold">Số lượng nhập</label>
                            <input type="number" class="form-control text-center fw-bold text-success" id="txtSoLuong" value="1" min="1">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Đơn vị tính</label>
                            <select id="slDVT" class="form-select">
                                <option value="Cái" selected>Cái</option>
                                <option value="Bộ">Bộ</option>
                                <option value="Thùng">Thùng</option>
                                <option value="Chiếc">Chiếc</option>
                                <option value="Kg">Kg</option>
                            </select>
                        </div>

                        <div class="col-12">
                            <label class="form-label small fw-bold">Đơn giá nhập (VNĐ)</label>
                            <div class="input-group">
                                <input type="number" class="form-control" id="txtDonGia" placeholder="Nhập giá tiền">
                                <span class="input-group-text">đ</span>
                            </div>
                        </div>
                    </div>
                </div>

               <!-- // NOTE: 5.2 FORM XUẤT HÀNG -->
<div id="formXuatHang" style="display:none;">
    <div class="row g-3">
        <div class="col-md-6">
            <label class="form-label small fw-bold">Mã SKU</label>
            <input type="text" class="form-control bg-light" id="iptMaSKU_Xuat" readonly>
        </div>
        <div class="col-md-6">
            <label class="form-label small fw-bold text-danger">Số hóa đơn xuất</label>
            <input type="text" class="form-control bg-light fw-bold text-danger" id="iptSoHoaDon_Xuat" readonly>
        </div>
        <div class="col-12">
            <label class="form-label small fw-bold">Sản phẩm xuất</label>
            <input type="text" id="lbTenSP_Xuat" class="form-control fw-bold bg-light" readonly>
        </div>
        <div class="col-12">
            <label class="form-label small fw-bold text-primary">Tên khách hàng</label>
            <input type="text" id="txtTenKhachHang" class="form-control" value="Khách lẻ">
        </div>
        <div class="col-6 text-center">
            <label class="form-label small fw-bold">Tồn kho</label>
            <div class="h4 text-secondary" id="lbSoLuong_Ton">0</div>
        </div>
        <div class="col-6">
            <label class="form-label small fw-bold text-danger">Số lượng xuất</label>
            <input type="number" id="txtSoLuongXuat" class="form-control text-center fw-bold border-danger" value="1">
        </div>
        <!-- THAY THẾ GHI CHÚ BẰNG 2 Ô DƯỚI ĐÂY -->
        <div class="col-6">
            <label class="form-label small fw-bold text-primary">Đơn giá bán</label>
            <div class="input-group">
                <input type="number" id="txtDonGiaXuat" class="form-control border-primary" placeholder="0">
                <span class="input-group-text text-primary">đ</span>
            </div>
        </div>
        <div class="col-6">
            <label class="form-label small fw-bold text-warning">Chiết khấu (%)</label>
            <div class="input-group">
                <input type="number" id="txtChietKhauXuat" class="form-control border-warning" value="0" min="0" max="100">
                <span class="input-group-text text-warning">%</span>
            </div>
        </div>
    </div>
</div>

                <!-- // NOTE: 5.3 XEM TRƯỚC HÓA ĐƠN -->
           <!-- // NOTE: 5.3 PREVIEW DÙNG CHUNG (Thêm id pvGC để hiện ghi chú) -->
<div id="previewHoaDon" style="display:none;" class="p-3 border border-2 border-dashed rounded-4 bg-white shadow-sm">
    <div class="text-center mb-3">
        <h6 id="pvTieuDe" class="fw-bold text-uppercase">Xác nhận phiếu kho</h6>
        <small id="pvNgay" class="text-muted"></small>
    </div>
    <table class="table table-sm table-borderless small mb-0">
        <tbody>
            <tr><td class="text-muted">Số hóa đơn:</td><td id="pvSHD" class="fw-bold text-end text-primary"></td></tr>
            <tr><td id="pvDoiTuongLabel" class="text-muted">Nhà Cung Cấp:</td><td id="pvNCC" class="fw-bold text-end"></td></tr>
            <tr><td class="text-muted">Sản phẩm:</td><td id="pvTenSP" class="fw-bold text-end text-dark"></td></tr>
            <tr><td class="text-muted">Số lượng:</td><td id="pvSL" class="fw-bold text-end text-danger"></td></tr>
            <tr id="trTongTien"><td class="fw-bold">Tổng tiền:</td><td id="pvTong" class="fw-bold text-end text-success"></td></tr>
            <tr id="trGhiChuXuat" style="display:none;"><td class="text-muted">Ghi chú:</td><td id="pvGC" class="fw-bold text-end small"></td></tr>
        </tbody>
    </table>
    <div class="text-center mt-3 border-top pt-2">
        <button type="button" class="btn btn-sm btn-link text-decoration-none" onclick="quayLaiNhap()"><i class="fas fa-edit me-1"></i> Sửa lại</button>
    </div>
</div>

            </div> <!-- Kết thúc modal-body -->

            <!-- Footer -->
                <div class="modal-footer border-0 bg-light rounded-bottom-4">
                    <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">Đóng</button>
                    
                    <!-- NÚT 1: Dùng chung để nhảy sang bước Preview (JS sẽ đổi chữ Xem HD Nhập/Xuất) -->
                    <button type="button" class="btn btn-primary px-4 shadow" id="btnXemTruoc" onclick="xuLyXemHoaDonChung()">Xem hóa đơn</button>
                    
                    <!-- NÚT 2: Chỉ hiện ở bước cuối cùng của NHẬP KHO -->
                    <button type="button" class="btn btn-success px-4 shadow" id="btnXacNhanNhap" style="display:none;" onclick="thucHienLuuDB()">Xác nhận Nhập</button>
                    
                    <!-- NÚT 3: Chỉ hiện ở bước cuối cùng của XUẤT KHO -->
                    <button type="button" class="btn btn-danger px-4 shadow" id="btnXacNhanXuat" style="display:none;" onclick="thucHienXuat()">Xác nhận Xuất</button>
                </div>

        </div>
    </div>
</div>

<!-- // NOTE: 6. MODAL THÊM NHÀ CUNG CẤP MỚI (PHẢI NẰM RIÊNG BIỆT) -->
<div class="modal fade" id="modalThemNCC" tabindex="-1" aria-hidden="true" style="z-index: 1060;">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title fw-bold"><i class="fas fa-plus-circle me-2"></i>Thêm nhà cung cấp</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="mb-3">
                    <label class="form-label fw-bold small">Tên nhà cung cấp</label>
                    <input type="text" class="form-control" id="txtNewTenNCC" placeholder="Nhập tên nhà cung cấp...">
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold small">Số điện thoại</label>
                    <input type="text" class="form-control" id="txtNewSDT" placeholder="Nhập SĐT...">
                </div>
                <div class="mb-0">
                    <label class="form-label fw-bold small">Địa chỉ</label>
                    <textarea class="form-control" id="txtNewDiaChi" rows="2" placeholder="Nhập địa chỉ..."></textarea>
                </div>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-success px-4" onclick="xacNhanThemNCC()">Lưu thông tin</button>
            </div>
        </div>
    </div>
</div>

<style>
/* CSS bổ sung để hỗ trợ việc ẩn hiện và làm nổi bật */
.highlight-blink {
    border: 3px solid #ff5722 !important; /* Màu cam nổi bật */
    box-shadow: 0 0 15px rgba(255, 87, 34, 0.7) !important;
    transform: scale(1.08); /* Phóng lớn nhẹ */
    z-index: 10;
    animation: pulse-search 1s infinite alternate;
}

@@keyframes pulse-search {
    from { opacity: 1; }
    to { opacity: 0.7; }
}

/* Đảm bảo grid không bị vỡ khi ẩn ô */
.storage-grid {
    display: grid !important; 
}

    /* 1. KHUNG LƯỚI 14 CỘT CHUẨN */
    .storage-grid {
        display: grid;
        /* Ép đúng 14 ô trên 1 hàng ngang */
        grid-template-columns: repeat(14, 1fr); 
        gap: 12px;
        margin-top: 10px;
    }

    /* 2. ĐỊNH NGHĨA Ô KHO (BIN BOX) */
    .bin-box {
        /* Dùng aspect-ratio thay vì cố định width/height để tự co giãn theo 14 cột */
        aspect-ratio: 1 / 1; 
        border-radius: 12px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        position: relative;
        font-weight: bold;
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        user-select: none;
        border: 2px solid transparent;
    }

    /* 3. TRẠNG THÁI Ô TRỐNG (EMPTY) */
    .bin-box.empty { 
        border: 2px dashed #dee2e6; 
        color: #adb5bd; 
        background-color: #f8f9fa !important; 
    }
    
    .bin-box.empty:hover {
        border-style: solid;
        border-color: #0d6efd; 
        color: #0d6efd;
        background-color: #fff !important;
    }

    /* 4. TRẠNG THÁI Ô CÓ HÀNG (OCCUPIED) */
    .bin-box.occupied { 
        background-color: #dc3545 !important; 
        color: white; 
        border: 2px solid #b02a37; 
        box-shadow: 0 4px 6px rgba(220, 53, 69, 0.2);
    }
    
    /* Hiệu ứng nhịp tim cho ô có hàng khi load */
    .occupied-animate {
        animation: pulse-red 1.2s ease-in-out infinite;
    }

    /* 5. HIỆU ỨNG KHI ĐƯỢC CHỌN (SELECTED) */
    .bin-box.selected {
        outline: 3px solid #ffc107;
        outline-offset: 3px;
        z-index: 10;
        transform: scale(1.1);
    }


    /* 6. HIỆU ỨNG HOVER CHUNG */
    .bin-box:hover { 
        transform: translateY(-5px) scale(1.05); 
        z-index: 5; 
        box-shadow: 0 8px 15px rgba(0,0,0,0.15); 
    }

    /* 7. CHI TIẾT CHỮ BÊN TRONG */
    .box-number {
        font-size: 1.2rem;
        margin-bottom: -2px;
    }

    .label-code { 
        font-size: 9px; 
        opacity: 0.8; 
        font-weight: normal; 
    }

    /* 8. CẤU HÌNH BANNER KHU VỰC (5 CỘT) */
    .col-md-2-4 { 
        width: 20%; 
        flex: 0 0 20%; 
    }
    /* Hiệu ứng khi ô đang có hàng nhưng số lượng thấp (Cảnh báo) */
.bin-box.occupied.low-stock {
    background-color: #ffc107 !important; /* Màu vàng */
    color: #000;
}

/* Tooltip hiển thị nhanh thông tin khi hover */
.bin-box:hover::after {
    content: attr(data-info); /* Bạn có thể dùng JS gán thêm attribute này */
    position: absolute;
    bottom: 110%;
    background: rgba(0,0,0,0.8);
    color: white;
    padding: 5px 10px;
    border-radius: 5px;
    font-size: 11px;
    white-space: nowrap;
    z-index: 100;
}
/* --- HIỆU ỨNG TÌM KIẾM THÔNG MINH --- */
/* CSS bổ sung để hỗ trợ việc ẩn hiện và làm nổi bật */
.highlight-blink {
    border: 3px solid #ff5722 !important; /* Màu cam nổi bật */
    box-shadow: 0 0 15px rgba(255, 87, 34, 0.7) !important;
    transform: scale(1.08); /* Phóng lớn nhẹ */
    z-index: 10;
    animation: pulse-search 1s infinite alternate;
}

@@keyframes pulse-search {
    from { opacity: 1; }
    to { opacity: 0.7; }
}

/* Đảm bảo grid không bị vỡ khi ẩn ô */
.storage-grid {
    display: grid !important; 
}

    /* 9. KEYFRAMES ANIMATION */
    @@keyframes pulse-red {
        0% { box-shadow: 0 0 0 0 rgba(220, 53, 69, 0.4); }
        70% { box-shadow: 0 0 0 10px rgba(220, 53, 69, 0); }
        100% { box-shadow: 0 0 0 0 rgba(220, 53, 69, 0); }
    }

