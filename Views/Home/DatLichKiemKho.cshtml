        }
    });
}
 
    // 2. Hàm Xem trước hóa đơn (Preview)
function xemTruocHoaDon() {
    const fields = {
        ncc: document.getElementById('iptTenNCC'),
        sp: document.getElementById('iptTenSP'),
        sl: document.getElementById('txtSoLuong'),
        dg: document.getElementById('txtDonGia'),
        shd: document.getElementById('iptSoHoaDon')
    };

    if (!fields.ncc.value || !fields.sp.value || fields.sl.value <= 0) {
        alert("⚠️ Vui lòng chọn đầy đủ Sản phẩm, NCC và Số lượng hợp lệ!");
        return;
    }

    // Đổ dữ liệu Preview (Giữ nguyên logic của Thiện)
    document.getElementById('pvTieuDe').innerText = "Xác nhận phiếu nhập kho";
    document.getElementById('pvTieuDe').className = "fw-bold text-uppercase text-success";
    document.getElementById('pvNCC').innerText = fields.ncc.options[fields.ncc.selectedIndex].text;
    document.getElementById('pvTenSP').innerText = fields.sp.options[fields.sp.selectedIndex].text;
    document.getElementById('pvSL').innerText = fields.sl.value;
    document.getElementById('pvSHD').innerText = fields.shd.value;
    
    const thanhTien = (parseInt(fields.sl.value) || 0) * (parseFloat(fields.dg.value) || 0);
    document.getElementById('pvTong').innerText = thanhTien.toLocaleString('vi-VN') + " đ";
    document.getElementById('pvNgay').innerText = "Ngày: " + new Date().toLocaleDateString('vi-VN');

    // --- PHẦN THAY ĐỔI GIAO DIỆN ---
    $("#formNhapHang").hide();
    $("#previewHoaDon").show();
    $("#trTongTien").show();
    $("#trGhiChuXuat").hide();

    // Điều khiển nút Footer
    $("#btnXemTruoc").hide();      // Ẩn nút "Xem hóa đơn"
    $("#btnXacNhanNhap").show();   // Hiện nút "Xác nhận Nhập" (Nút màu xanh)
    $("#btnXacNhanXuat").hide();
}
// --- 2. Hàm Preview dành riêng cho Xuất ---
function xemTruocHoaDonXuat() {
    const slXuat = parseInt(document.getElementById('txtSoLuongXuat').value) || 0;
    const slTon = parseInt(document.getElementById('lbSoLuong_Ton').innerText) || 0;
    const dgXuat = parseFloat(document.getElementById('txtDonGiaXuat').value) || 0;
    const ckXuat = parseFloat(document.getElementById('txtChietKhauXuat').value) || 0;

    if (slXuat <= 0 || slXuat > slTon) {
        alert("⚠️ Số lượng xuất không hợp lệ hoặc vượt quá tồn kho!");
        return;
    }
    if (dgXuat < 0) {
        alert("⚠️ Đơn giá không được nhỏ hơn 0!");
        return;
    }
    // Công thức tính tiền
    const thanhTien = slXuat * dgXuat;
    const tienChietKhau = thanhTien * (ckXuat / 100);
    const tongCuoiCung = thanhTien - tienChietKhau;

    // Đổ dữ liệu Preview
    document.getElementById('pvTieuDe').innerText = "Xác nhận phiếu xuất kho";
    document.getElementById('pvTieuDe').className = "fw-bold text-uppercase text-danger";
    document.getElementById('pvDoiTuongLabel').innerText = "Khách hàng:";
    document.getElementById('pvNCC').innerText = document.getElementById('txtTenKhachHang').value;
    document.getElementById('pvTenSP').innerText = document.getElementById('lbTenSP_Xuat').value;
    document.getElementById('pvSL').innerText = slXuat + " Cái";
    document.getElementById('pvSHD').innerText = document.getElementById('iptSoHoaDon_Xuat').value;
    document.getElementById('pvSL').innerText = slXuat + " (CK: " + ckXuat + "%)";

    // Hiển thị tổng tiền
    const pvTong = document.getElementById('pvTong');
    pvTong.innerText = tongCuoiCung.toLocaleString('vi-VN') + " đ";
    pvTong.className = "fw-bold text-end text-danger"; // Đổi màu đỏ cho phiếu xuất


    document.getElementById('pvNgay').innerText = "Ngày: " + new Date().toLocaleDateString('vi-VN');

    // --- PHẦN THAY ĐỔI GIAO DIỆN ---
    $("#formXuatHang").hide();
    $("#previewHoaDon").show();
    $("#trTongTien").show();       // Xuất kho chưa cần tổng tiền
    $("#trGhiChuXuat").hide();     // Hiện ghi chú xuất hàng

    // Điều khiển nút Footer
    $("#btnXemTruoc").hide();      // Ẩn nút "Xem hóa đơn"
    $("#btnXacNhanNhap").hide();
    $("#btnXacNhanXuat").show();   // Hiện nút "Xác nhận Xuất" (Nút màu đỏ)
}
function xuLyXemHoaDonChung() {
    // Kiểm tra xem Form nào đang hiển thị để gọi hàm Preview tương ứng
    if ($("#formXuatHang").is(":visible")) {
        xemTruocHoaDonXuat();
    } else {
        xemTruocHoaDon();
    }
}

function quayLaiNhap() {
    // 1. Ẩn vùng Preview đi
    $("#previewHoaDon").hide();

    // 2. Kiểm tra tiêu đề của Preview để biết đang ở luồng nào
    const tieuDe = document.getElementById('pvTieuDe').innerText.toUpperCase();
    const isLuongXuat = tieuDe.includes("XUẤT");

    if (isLuongXuat) {
        // Nếu đang là luồng Xuất -> Quay về Form Xuất
        $("#formXuatHang").show();
        $("#formNhapHang").hide();
        
        // Cấu hình lại nút Xem hóa đơn cho đúng màu đỏ của Xuất
        const btnXem = document.getElementById('btnXemTruoc');
        btnXem.style.display = 'block';
        btnXem.innerText = "Xem hóa đơn xuất";
        btnXem.className = "btn btn-danger px-4 shadow";
    } else {
        // Nếu đang là luồng Nhập -> Quay về Form Nhập
        $("#formNhapHang").show();
        $("#formXuatHang").hide();
        
        // Cấu hình lại nút Xem hóa đơn cho đúng màu xanh của Nhập
        const btnXem = document.getElementById('btnXemTruoc');
        btnXem.style.display = 'block';
        btnXem.innerText = "Xem hóa đơn nhập";
        btnXem.className = "btn btn-primary px-4 shadow";
    }

    // 3. Ẩn các nút xác nhận cuối cùng đi
    $("#btnXacNhanNhap").hide();
    $("#btnXacNhanXuat").hide();
}


    function thucHienLuuDB() {
const vtId = document.getElementById('txtViTriID_Hidden')?.value || 0;
    const khuId = document.getElementById('txtKhuID_Hidden')?.value || 0;
    const khoId = document.getElementById('txtKhoId_Hidden')?.value || 1;
    const maViTriText = document.getElementById('titleMaViTri').innerText.replace("Vị trí: ", "").trim();
    const selNCC = document.getElementById('iptTenNCC');
    const selSP = document.getElementById('iptTenSP');
    const TenNV = document.getElementById('iptNguoiThucHien').value || 
                  document.getElementById('txtNhanVienHienTai').value || "Hệ thống";
    const ghiChuTuDong = "Nhập bởi: " + TenNV;
    const payload = {
        ViTriID: parseInt(vtId),
        KhuId: parseInt(document.getElementById('txtKhuID_Hidden').value), // Đổi tên từ DanhMucID thành KhuId
        KhoId: parseInt(document.getElementById('txtKhoId_Hidden').value), // Đảm bảo có KhoId để lọc lịch sử
        SanPhamID: parseInt(selSP.value),
        TenSP: selSP.options[selSP.selectedIndex].text,
        TenNCC: selNCC.options[selNCC.selectedIndex].text,
        NhaCungCapID: parseInt(selNCC.value),
        DiaChiNCC: "N/A", 
        SoDienThoaiNCC: "N/A",
        MaSKU: document.getElementById('iptMaSKU').value,
        SoLuong: parseInt(document.getElementById('txtSoLuong').value) || 0,
        DonGiaNhap: parseFloat(document.getElementById('txtDonGia').value) || 0,
        SoHoaDon: document.getElementById('iptSoHoaDon').value,
        GhiChu: ghiChuTuDong, 
        NhanVienThucHien: TenNV
    };
    fetch('/Home/LuuNhapKhoTuDo', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
    })
    .then(res => res.json())
    .then(result => {
        if (result.success) {
            alert("Đã nhập kho thành công !");
            location.reload(); 
        } else {
            alert("❌ Lỗi hệ thống: " + (result.message || "Kiểm tra lại dữ liệu nhập"));
        }
    })
    .catch(err => {
        console.error("Lỗi Fetch POST:", err);
        alert("❌ Lỗi kết nối! Thiện hãy kiểm tra lại đường truyền nhé.");
    });
} 
