                <input type="hidden" id="txtKhoId_Hidden" value="@ViewBag.KhoId" />
                <input type="hidden" id="hdnSanPhamID" />
                <input type="hidden" id="hdnDonGia" value="@ViewBag.DonGia" />
                <!-- // NOTE: 5.1 FORM NHẬP HÀNG -->
                <div id="formNhapHang" style="display:none;">
                    <div class="row mb-3">
                        <div class="col-md-12">
                            <label class="form-label fw-bold text-primary"><i class="fas fa-user-edit"></i> Người thực hiện:</label>
