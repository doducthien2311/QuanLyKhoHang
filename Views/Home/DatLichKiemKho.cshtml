@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@{
    // Lấy giá trị từ Session và ép kiểu về String để không bị báo đỏ
    string quyen = HttpContextAccessor.HttpContext.Session.GetString("UserRole") ?? "";
}
@using QuanLyKhoLogistics.Models.Entities
@model IEnumerable<QuanLyKhoLogistics.Models.Entities.OKho>
@{
    ViewData["Title"] = "Quản lý chi tiết - " + (ViewBag.TenKho ?? "Kho hàng");
    Layout = "~/Views/Shared/_Layout.cshtml";

    var danhSachKhu = ViewBag.ListKhuVuc as List<KhuVuc> ?? new List<KhuVuc>();
    int currentKhuId = ViewBag.KhuHienTaiId ?? (danhSachKhu.FirstOrDefault()?.KhuId ?? 1);
    var khuHienTai = danhSachKhu.FirstOrDefault(k => k.KhuId == currentKhuId);

    // Mẹo: Tạo mảng ký tự để map KhuId 1 -> A, 2 -> B...
    string[] kyTuKhu = { "A", "B", "C", "D", "E", "F", "G" };
    // Lấy index dựa trên vị trí của khu hiện tại trong danh sách
    int indexKhu = danhSachKhu.IndexOf(khuHienTai ?? new KhuVuc());
    string maKhuHienTai = (indexKhu >= 0 && indexKhu < kyTuKhu.Length) ? kyTuKhu[indexKhu] : "N/A";
  var tenNguoiDung = Context.Session.GetString("UserName") ?? "Admin Hệ Thống";
}

 <div class="container-fluid py-4">
    <!-- // NOTE: 1. BANNER HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4 bg-white p-3 rounded-4 shadow-sm border-start border-4 border-success">
        <div class="d-flex align-items-center">
           
            <a href="/Home/KhoHang" class="btn btn-light rounded-circle">
                <i class="fas fa-arrow-left"></i>
            </a>
            <div>
                <h4 class="fw-bold mb-0 text-dark text-uppercase">@ViewBag.TenKho</h4>
                <div class="text-muted small">
                    <i class="fas fa-check-circle text-success me-1"></i> Trạng thái: Đang hoạt động
                </div>
            </div>
        </div>
        <div class="d-flex gap-2">
        @* Đảm bảo Model của trang này có chứa KhoId *@
            <!-- Cách viết trong thẻ <a> -->
                @* Dùng @ViewContext.RouteData.Values["id"] để bốc đúng ID của kho từ thanh địa chỉ *@
                <a href="/Home/LichSuKiemKe/@ViewContext.RouteData.Values["id"]" class="btn btn-warning">
                    <i class="fas fa-history"></i> Lịch Sử Kiểm Kê
                </a>
            <a href="/Home/KhoHang" class="btn btn-outline-dark">
                <i class="fas fa-reply"></i> Quay lại
            </a>
        </div>
    </div>

    <!-- // NOTE: 2. NAVIGATION CÁC KHU -->
    <div class="row g-3 mb-4">
        @foreach (var khu in danhSachKhu)
        {
            bool isActive = currentKhuId == khu.KhuId;
            <div class="col-md-2-4 col-sm-6">
                <a href="@Url.Action("DatLichKiemKho", new { id = ViewBag.KhoId, khuId = khu.KhuId })" 
                   class="card border-0 shadow-sm p-3 text-center text-decoration-none rounded-4 @(isActive ? "bg-success text-white shadow-lg" : "bg-white text-dark")">
                    <div class="fw-bold mb-1">Khu @khu.TenKhu</div>
                    <div class="small opacity-75">Diện tích: @(string.IsNullOrEmpty(khu.DienTich) ? "120m²" : khu.DienTich)</div>
                </a>
            </div>
        }
    </div>
    <!-- // NOTE:  ô tìm kiếm -->
<div class="card shadow-sm border-0 rounded-4 mb-3">
    <div class="card-body p-3">
        <div class="row align-items-center">
            <div class="col-md-6">
                <div class="input-group">
                    <span class="input-group-text bg-light border-0">
                        <i class="fas fa-search text-success"></i>
                    </span>
                    <input type="text" 
                           id="input-tim-kho" 
                           class="form-control border-0 bg-light shadow-none" 
                           placeholder="Thiện muốn tìm sản phẩm hoặc vị trí nào?">
                </div>
            </div>
            <div class="col-md-6 text-end">
                <span class="badge bg-label-success text-success p-2">
                    <i class="fas fa-info-circle me-1"></i> Tự động lọc khi gõ
                </span>
            </div>
        </div>
    </div>
</div>
    <!-- // NOTE: 3. SƠ ĐỒ LƯỚI 14 CỘT -->
    <div class="card shadow-sm border-0 rounded-4 p-4">
        <div class="text-center mb-3 border-bottom pb-2">
    <h6 class="fw-bold mb-0 text-uppercase text-success" style="letter-spacing: 1px;">
        <i class="fas fa-th-large me-2"></i>
        SƠ ĐỒ: KHU @(khuHienTai?.TenKhu ?? "") (MÃ @maKhuHienTai)
    </h6>
</div>

        
     <div 
        
        class="storage-grid">
            @if (Model != null && Model.Any())
            {
                int stt = 1;
                                foreach (var item in Model)
                                {
                                    bool isOccupied = (item.TrangThai == 1); 
            <div class="bin-box @(isOccupied ? "occupied" : "empty") o-kho-item" 
                    id="o-kho-@item.ViTriId" 
                    data-ten="@item.TenSP?.ToLower()" 
                    data-danhmuc="@item.TenDanhMuc?.ToLower()"
                    onclick="xemChiTietO('@item.ViTriId', '@item.MaViTri', '@(isOccupied ? "true" : "false")')"
                    style="cursor:pointer;">
                    <span class="box-number">@stt</span>
                    <div class="label-code">@item.MaViTri</div>
                    
                    @if(isOccupied) {
                        <div class="small-product-name" style="font-size: 0.6rem; color: #dc3545; position: absolute; bottom: 15px; width: 100%; text-align: center;">
                            @item.TenSP
                        </div>
                        <i class="fas fa-box small text-danger" style="position:absolute; bottom:5px; right:5px;"></i>
                    }
                </div>
                    stt++;
                }
            }
        </div> <!-- Kết thúc storage-grid -->
    </div> <!-- Kết thúc card sơ đồ -->
</div> <!-- Kết thúc container-fluid -->

<!-- // NOTE: 4. CÁC INPUT HIDDEN PHỤC VỤ JS -->
<input type="hidden" id="txtNhanVienHienTai" value="@tenNguoiDung" />

<!-- // NOTE: 5. MODAL THAO TÁC CHÍNH (NHẬP/XUẤT) -->
<div class="modal fade" id="modalThaoTac" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <!-- Header -->
            <div class="modal-header bg-light">
