@using QuanLyKhoLogistics.Models.Entities
@model List<KhoSummary>

@{
    ViewData["Title"] = "Quản lý Kho hàng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid bg-light py-4 px-4 min-vh-100">
    <div class="row g-4">
        @* 1. Sidebar bên trái *@
        <div class="col-md-3 col-lg-2">
            @await Html.PartialAsync("~/Views/Shared/Partials/KhoHang/_KH-Sidebar.cshtml")
        </div>

        <div class="col-md-9 col-lg-10">
            @* 2. Header *@
            @await Html.PartialAsync("~/Views/Shared/Partials/KhoHang/_KH-Header.cshtml")
            
            @* 3. Danh sách Card lấy dữ liệu từ hàm TongQuanHeThongKho *@
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4">
                @foreach (var item in Model)
                {
                    // ĐỒNG BỘ LOGIC ẢNH: Thiện gán ảnh dựa vào TenKho lấy từ DB
                    string hinhAnhCuaToi = "/images/kho-mau.jpg";
                    if (item.TenKho.Contains("Hoàng Mai")) hinhAnhCuaToi = "/images/kho_hoang_mai.jpg";
                    else if (item.TenKho.Contains("Long Biên")) hinhAnhCuaToi = "/images/kho_long_bien.jpg";
                    else if (item.TenKho.Contains("Ba Đình")) hinhAnhCuaToi = "/images/kho_ba_dinh.jpg";
                    else if (item.TenKho.Contains("Đống Đa")) hinhAnhCuaToi = "/images/kho_dong_da.jpg";

                    <div class="col">
                        <div class="card h-100 shadow-sm border-0" style="border-radius: 15px; transition: transform 0.2s;">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h5 class="fw-bold text-uppercase" style="color: #e67e22;">@item.TenKho</h5>
                                    <i class="far fa-heart text-secondary" style="cursor: pointer;"></i>
                                </div>
                                 
                                <img src="@hinhAnhCuaToi" 
                                     class="img-fluid rounded mb-3 shadow-sm" 
                                     alt="@item.TenKho"
                                     style="height: 160px; width: 100%; object-fit: cover;">

                                <p class="small text-muted mb-1">
                                    <i class="fas fa-map-marker-alt text-success me-1"></i> @item.DiaChi
                                </p>

                              <p class="small mb-1">
                                    <i class="fas fa-box text-warning me-1"></i> 
                                    Hàng hóa: <strong>@item.TongSanPham.ToString("N0") SP</strong>
                              </p>
                                
                                <p class="small mb-2">
                                    <i class="fas fa-th text-info me-1"></i> Sức chứa: <strong>@item.SoODaCoHang / @item.TongSoO ô</strong>
                                </p>

                                <div class="mt-3">
                                    <div class="d-flex justify-content-between mb-1">
                                        @* Lấy đúng thuộc tính PhanTramSucChua từ Class KhoSummary *@
                                        <span class="small fw-bold text-muted">@Math.Round(item.PhanTramSucChua, 1)%</span>
                                        <span class="badge @(item.PhanTramSucChua >= 90 ? "bg-danger" : item.PhanTramSucChua >= 70 ? "bg-warning" : "bg-success") rounded-pill">
                                            @item.TrangThaiText
                                        </span>
                                    </div>
                                    <div class="progress" style="height: 8px; border-radius: 10px; background-color: #e9ecef;">
                                        <div class="progress-bar @(item.PhanTramSucChua >= 90 ? "bg-danger" : item.PhanTramSucChua >= 70 ? "bg-warning" : "bg-success") progress-bar-striped progress-bar-animated" 
                                             role="progressbar" 
                                             style="width: @item.PhanTramSucChua%"></div>
                                    </div>
                                </div>

                                @* SỬA LINK: Dẫn đến hàm KhoHang(int id) để xem sơ đồ 100 ô *@
                                <a href="/Home/KhoHang/@item.KhoId" class="btn btn-success w-100 mt-3 fw-bold py-2 shadow-sm" style="border-radius: 10px;">
                                    <i class="fas fa-tasks me-1"></i> QUẢN LÝ KHO
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }
</style>